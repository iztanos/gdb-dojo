#!/usr/bin/env bash
set -e

repo_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$repo_dir"

. "$repo_dir/lib/dojo-ui.sh"

print_help() {
    dojo_clear
    dojo_header "GDB DOJO" "Practical GDB training"
    echo
    printf "%bRepository map%b\n" "$BOLD$CYAN" "$RESET"
    echo "  levels/story/00-lobby/00-welcome-desk"
    echo "  levels/story/00-lobby/01-glass-box"
    echo "  levels/story/00-lobby/02-moving-door"
    echo "  levels/story/00-lobby/03-seggy-fault"
    echo
    printf "%bTypical flow%b\n" "$BOLD$CYAN" "$RESET"
    dojo_cmd "cd levels/story/00-lobby/00-welcome-desk"
    dojo_cmd "start"
    dojo_cmd "make"
    dojo_cmd "./welcome"
    echo
    echo "Commands:"
    echo "  dojo paths    show exercise paths"
    echo "  dojo story    show Story Mode levels"
    echo "  dojo lobby    show Level 0 exercises"
    echo "  dojo modes    show planned modes"
    echo "  dojo help     show this screen"
}

show_modes() {
    dojo_clear
    printf "%bModes%b\n\n" "$BOLD$CYAN" "$RESET"
    printf "%-16s  %-9s  %s\n" "Mode" "Status" "Best for"
    printf "%-16s  %-9s  %s\n" "--------------" "---------" "----------------------------------"
    printf "%-16s  %-9s  %s\n" "Story Mode" "started" "first-time GDB users"
    printf "%-16s  %-9s  %s\n" "Beginner" "planned" "standalone skill drills"
    printf "%-16s  %-9s  %s\n" "Intermediate" "planned" "realistic debugging tasks"
    printf "%-16s  %-9s  %s\n" "Advanced" "planned" "harder scenarios"
}

show_story() {
    dojo_clear
    printf "%bStory Mode%b\n\n" "$BOLD$CYAN" "$RESET"
    printf "%-10s  %-9s  %s\n" "Level" "Status" "Path"
    printf "%-10s  %-9s  %s\n" "----------" "---------" "---------------------------"
    printf "%-10s  %-9s  %s\n" "00-lobby" "active" "levels/story/00-lobby"
}

show_lobby() {
    dojo_clear
    dojo_header "STORY MODE / LEVEL 0" "The Lobby"
    echo
    printf "%-18s  %-26s  %s\n" "Exercise" "Skill" "Path"
    printf "%-18s  %-26s  %s\n" "------------------" "--------------------------" "-------------------------------------------"
    printf "%-18s  %-26s  %s\n" "00-welcome-desk" "build, run, submit" "levels/story/00-lobby/00-welcome-desk"
    printf "%-18s  %-26s  %s\n" "01-glass-box" "run inside GDB" "levels/story/00-lobby/01-glass-box"
    printf "%-18s  %-26s  %s\n" "02-moving-door" "breakpoint at main" "levels/story/00-lobby/02-moving-door"
    printf "%-18s  %-26s  %s\n" "03-seggy-fault" "inspect local variables" "levels/story/00-lobby/03-seggy-fault"
    echo
    printf "%bUse:%b\n" "$GREEN" "$RESET"
    dojo_cmd "cd levels/story/00-lobby/00-welcome-desk"
    dojo_cmd "start"
}

show_paths() {
    dojo_clear
    printf "%bExercise paths%b\n\n" "$BOLD$CYAN" "$RESET"
    echo "levels/story/00-lobby/00-welcome-desk"
    echo "levels/story/00-lobby/01-glass-box"
    echo "levels/story/00-lobby/02-moving-door"
    echo "levels/story/00-lobby/03-seggy-fault"
    echo
    printf "%bExample%b\n" "$BOLD$CYAN" "$RESET"
    dojo_cmd "cd levels/story/00-lobby/01-glass-box"
    dojo_cmd "start"
}

case "${1:-help}" in
    help|-h|--help)
        print_help
        ;;
    modes)
        show_modes
        ;;
    story)
        show_story
        ;;
    lobby)
        show_lobby
        ;;
    paths)
        show_paths
        ;;
    *)
        dojo_error "Unknown command: $1"
        echo
        print_help
        exit 1
        ;;
esac
