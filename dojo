#!/usr/bin/env bash
set -e

repo_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$repo_dir"

. "$repo_dir/lib/dojo-ui.sh"

print_help() {
    dojo_clear
    dojo_header "GDB DOJO" "Practical GDB training"
    echo
    printf "%bRepository map%b\n" "$BOLD$CYAN" "$RESET"
    echo "  levels/guided/00-basics"
    echo "  levels/beginner"
    echo "  levels/intermediate"
    echo "  levels/advanced"
    echo
    printf "%bTypical flow%b\n" "$BOLD$CYAN" "$RESET"
    dojo_cmd "cd levels/guided/00-basics/00-build-and-run"
    dojo_cmd "start"
    dojo_cmd "make"
    dojo_cmd "./build-and-run"
    echo
    echo "Commands:"
    echo "  dojo paths"
    echo "  dojo guided"
    echo "  dojo basics"
    echo "  dojo modes"
    echo "  dojo help"
}

show_modes() {
    dojo_clear
    printf "%bModes%b\n\n" "$BOLD$CYAN" "$RESET"
    printf "%-14s  %-9s  %s\n" "Mode" "Status" "Best for"
    printf "%-14s  %-9s  %s\n" "--------------" "---------" "--------------------------------"
    printf "%-14s  %-9s  %s\n" "Guided Path" "available" "first-time GDB users"
    printf "%-14s  %-9s  %s\n" "Beginner" "planned" "standalone skill drills"
    printf "%-14s  %-9s  %s\n" "Intermediate" "planned" "realistic debugging tasks"
    printf "%-14s  %-9s  %s\n" "Advanced" "planned" "harder scenarios"
}

show_guided() {
    dojo_clear
    printf "%bGuided Path%b\n\n" "$BOLD$CYAN" "$RESET"
    printf "%-10s  %-8s  %s\n" "Level" "Status" "Focus"
    printf "%-10s  %-8s  %s\n" "----------" "--------" "-----------------------------------"
    printf "%-10s  %-8s  %s\n" "00-basics" "complete" "core GDB workflow"
    printf "%-10s  %-8s  %s\n" "01" "planned" "breakpoint control"
}

show_basics() {
    dojo_clear
    dojo_header "GUIDED PATH / BASICS" "Core GDB workflow"
    echo
    printf "%-24s  %-28s  %s\n" "Exercise" "Skill" "Path"
    printf "%-24s  %-28s  %s\n" "------------------------" "----------------------------" "---------------------------------------------"
    printf "%-24s  %-28s  %s\n" "00-build-and-run" "build and run" "levels/guided/00-basics/00-build-and-run"
    printf "%-24s  %-28s  %s\n" "01-run-in-gdb" "run inside GDB" "levels/guided/00-basics/01-run-in-gdb"
    printf "%-24s  %-28s  %s\n" "02-first-breakpoint" "break at main, continue" "levels/guided/00-basics/02-first-breakpoint"
    printf "%-24s  %-28s  %s\n" "03-inspect-locals" "info locals, print" "levels/guided/00-basics/03-inspect-locals"
    printf "%-24s  %-28s  %s\n" "04-step-into-functions" "step, finish" "levels/guided/00-basics/04-step-into-functions"
    printf "%-24s  %-28s  %s\n" "05-basics-capstone" "combined workflow" "levels/guided/00-basics/05-basics-capstone"
    echo
    printf "%bUse:%b\n" "$GREEN" "$RESET"
    dojo_cmd "cd levels/guided/00-basics/00-build-and-run"
    dojo_cmd "start"
}

show_paths() {
    dojo_clear
    printf "%bExercise paths%b\n\n" "$BOLD$CYAN" "$RESET"
    echo "levels/guided/00-basics/00-build-and-run"
    echo "levels/guided/00-basics/01-run-in-gdb"
    echo "levels/guided/00-basics/02-first-breakpoint"
    echo "levels/guided/00-basics/03-inspect-locals"
    echo "levels/guided/00-basics/04-step-into-functions"
    echo "levels/guided/00-basics/05-basics-capstone"
    echo
    printf "%bExample%b\n" "$BOLD$CYAN" "$RESET"
    dojo_cmd "cd levels/guided/00-basics/01-run-in-gdb"
    dojo_cmd "start"
}

case "${1:-help}" in
    help|-h|--help)
        print_help
        ;;
    modes)
        show_modes
        ;;
    guided)
        show_guided
        ;;
    basics)
        show_basics
        ;;
    paths)
        show_paths
        ;;
    *)
        dojo_error "Unknown command: $1"
        echo
        print_help
        exit 1
        ;;
esac
