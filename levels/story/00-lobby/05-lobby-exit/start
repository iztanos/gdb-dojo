#!/usr/bin/env bash
set -e

exercise_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_dir="$(cd "$exercise_dir/../../../.." && pwd)"
cd "$exercise_dir"

. "$repo_dir/lib/dojo-ui.sh"

dojo_clear

dojo_header "05: LOBBY EXIT" "Level 0 capstone"
echo

cat <<'EOF'
Mission
  Trace the lobby exit mechanism.
  Find the value stored in exit_token.

Skills reviewed
  break main
  run
  next
  step
  finish
  print
  continue
  quit

Commands
EOF
dojo_cmd "make"
dojo_cmd "gdb -q ./lobby-exit"
echo

cat <<'EOF'
Inside GDB
EOF
dojo_cmd "break main"
dojo_cmd "run"
dojo_cmd "next"
dojo_cmd "step"
dojo_cmd "finish"
dojo_cmd "next"
dojo_cmd "print exit_token"
dojo_cmd "continue"
dojo_cmd "quit"
echo

cat <<'EOF'
Submit
EOF
dojo_cmd "./check.sh EXIT_TOKEN"
echo

cat <<'EOF'
"You know enough now to become dangerous to small programs."
EOF
