#!/usr/bin/env bash
set -e

exercise_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_dir="$(cd "$exercise_dir/../../../.." && pwd)"
cd "$exercise_dir"

. "$repo_dir/lib/dojo-ui.sh"

dojo_clear

dojo_header "03: SEGGY FAULT"
echo

cat <<'EOF'
Mission
  Find the value stored in the local variable:

    access_code

Normal program output will not reveal it.

Commands
EOF
dojo_cmd "make"
dojo_cmd "gdb -q ./seggy-fault"
echo

cat <<'EOF'
Inside GDB
EOF
dojo_cmd "break main"
dojo_cmd "run"
dojo_cmd "next"
dojo_cmd "next"
dojo_cmd "info locals"
dojo_cmd "print access_code"
dojo_cmd "quit"
echo

cat <<'EOF'
Submit
EOF
dojo_cmd "./check.sh ACCESS_CODE"
echo

cat <<'EOF'
"Some mistakes are bugs. Mine are Seggy faults."
EOF
