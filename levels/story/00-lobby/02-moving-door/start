#!/usr/bin/env bash
set -e

exercise_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_dir="$(cd "$exercise_dir/../../../.." && pwd)"
cd "$exercise_dir"

. "$repo_dir/lib/dojo-ui.sh"

dojo_clear

dojo_header "02: THE MOVING DOOR"
echo

cat <<'EOF'
"Breakpoints are how we teach time to behave."

Mission:
  Build the program.
  Open it in GDB.
  Set a breakpoint at main.
  Run, continue, and submit the door word.

You will practice:
  - setting a breakpoint
  - starting execution with run
  - resuming execution with continue

Type these next:
EOF

dojo_cmd "make"
dojo_cmd "gdb -q ./moving-door"
echo

echo "Inside GDB:"
dojo_cmd "break main"
dojo_cmd "run"
dojo_cmd "continue"
dojo_cmd "quit"
echo

echo "Then submit:"
dojo_cmd "./check.sh DOOR_WORD"
