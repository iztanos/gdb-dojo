#!/usr/bin/env bash
set -e

exercise_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_dir="$(cd "$exercise_dir/../../../.." && pwd)"
cd "$exercise_dir"

. "$repo_dir/lib/dojo-ui.sh"

dojo_clear

dojo_header "00: THE WELCOME DESK IS WATCHING"
echo

cat <<'EOF'
Seggy is sitting on the welcome desk.
The badge printer is awake. That is not a good sign.

Mission:
  Build the program.
  Run it.
  Submit the badge word it prints.

You will type:
EOF

dojo_cmd "make"
dojo_cmd "./welcome"
dojo_cmd "./check.sh BADGE_WORD"
echo

cat <<'EOF'
Files:
EOF
dojo_print_file_list
