#!/usr/bin/env bash
set -e

exercise_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_dir="$(cd "$exercise_dir/../../../.." && pwd)"
cd "$exercise_dir"

. "$repo_dir/lib/dojo-ui.sh"

dojo_clear

dojo_header "GUIDED PATH / BASICS" "Exercise 03: Inspect Local Variables"
echo

cat <<'EOF'
Skill
  Inspect variables that are not printed by the program.

Goal
  Find the value stored in access_code.

Build
EOF
dojo_cmd "make"
echo

cat <<'EOF'
Debug
EOF
dojo_cmd "gdb -q ./inspect-locals"
echo

cat <<'EOF'
Inside GDB
EOF
dojo_cmd "break main"
dojo_cmd "run"
dojo_cmd "next"
dojo_cmd "info locals"
dojo_cmd "print access_code"
dojo_cmd "quit"
echo

cat <<'EOF'
Submit
EOF
dojo_cmd "./check.sh ACCESS_CODE"
