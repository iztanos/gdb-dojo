#!/usr/bin/env bash
set -e

exercise_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_dir="$(cd "$exercise_dir/../../../.." && pwd)"
cd "$exercise_dir"

. "$repo_dir/lib/dojo-ui.sh"

dojo_clear

dojo_header "GUIDED PATH / BASICS" "Exercise 01: Run in GDB"
echo

cat <<'EOF'
Skill
  Start GDB, run a program, and quit GDB.

Goal
  Run the program from inside GDB and submit the status value it prints.

Build
EOF
dojo_cmd "make"
echo

cat <<'EOF'
Debug
EOF
dojo_cmd "gdb -q ./run-in-gdb"
echo

cat <<'EOF'
Inside GDB
EOF
dojo_cmd "run"
dojo_cmd "quit"
echo

cat <<'EOF'
Submit
EOF
dojo_cmd "./check.sh STATUS_VALUE"
