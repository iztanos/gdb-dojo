#!/usr/bin/env bash
set -e

exercise_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_dir="$(cd "$exercise_dir/../../../.." && pwd)"
cd "$exercise_dir"

. "$repo_dir/lib/dojo-ui.sh"

dojo_clear

dojo_header "GUIDED PATH / BASICS" "Exercise 02: First Breakpoint"
echo

cat <<'EOF'
Skill
  Set a breakpoint at main and continue execution.

Goal
  Stop at main, then continue until the program prints its status.

Build
EOF
dojo_cmd "make"
echo

cat <<'EOF'
Debug
EOF
dojo_cmd "gdb -q ./first-breakpoint"
echo

cat <<'EOF'
Inside GDB
EOF
dojo_cmd "break main"
dojo_cmd "run"
dojo_cmd "continue"
dojo_cmd "quit"
echo

cat <<'EOF'
Submit
EOF
dojo_cmd "./check.sh CONTINUED"
